{
  "expo": {
    "name": "TBP Mobile",
    "slug": "tbp-mobile",
    "version": "1.0.0",
    "scheme": "tbp",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A1A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tbgroup.tbpmobile",
      "associatedDomains": [
        "applinks:tbpmobile.com",
        "applinks:www.tbpmobile.com",
        "applinks:tbp.group",
        "appclips:tbpmobile.com"
      ],
      "infoPlist": {
        "NSCameraUsageDescription": "Used to scan QR codes on tickets",
        "NSCalendarsUsageDescription": "Add events to your calendar",
        "NSLocationWhenInUseUsageDescription": "Find events happening near you"
      },
      "appClip": {
        "bundleIdentifier": "com.tbgroup.tbpmobile.Clip",
        "associatedDomains": [
          "applinks:tbpmobile.com",
          "applinks:tbp.group"
        ],
        "entitlements": {
          "com.apple.developer.parent-application-identifiers": [
            "$(AppIdentifierPrefix)com.tbgroup.tbpmobile"
          ]
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A0A1A",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.tbgroup.tbpmobile",
      "permissions": [
        "CAMERA",
        "READ_CALENDAR",
        "WRITE_CALENDAR",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "tbpmobile.com",
              "pathPrefix": "/event"
            },
            {
              "scheme": "https",
              "host": "tbpmobile.com",
              "pathPrefix": "/dj"
            },
            {
              "scheme": "https",
              "host": "tbpmobile.com",
              "pathPrefix": "/tickets"
            },
            {
              "scheme": "https",
              "host": "tbpmobile.com",
              "pathPrefix": "/discover"
            },
            {
              "scheme": "https",
              "host": "tbpmobile.com",
              "pathPrefix": "/feed"
            },
            {
              "scheme": "https",
              "host": "www.tbpmobile.com",
              "pathPrefix": "/event"
            },
            {
              "scheme": "https",
              "host": "www.tbpmobile.com",
              "pathPrefix": "/dj"
            },
            {
              "scheme": "https",
              "host": "tbp.group",
              "pathPrefix": "/event"
            },
            {
              "scheme": "https",
              "host": "tbp.group",
              "pathPrefix": "/dj"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-camera",
      "expo-secure-store",
      "@stripe/stripe-react-native",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Find events happening near you"
        }
      ],
      "expo-linking"
    ]
  }
}
